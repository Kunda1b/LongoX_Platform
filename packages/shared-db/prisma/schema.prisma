// =============================================================================
// LongoX Canonical Database Schema — Prisma
// =============================================================================
// Source of truth: architecture.md Section 10 (PostgreSQL Schema Catalog)
// Per Section 29.2: Prisma is the long-term canonical schema and migration layer.
// Drizzle ORM (packages/shared-db/src/schema/) remains as a temporary
// compatibility layer until all services are migrated.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm, btree_gin]
}

// =============================================================================
// Domain: Identity
// =============================================================================

/// Multi-tenancy root — every row in a tenant-scoped table carries tenant_id.
model Tenant {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  status              String   @default("active") // active | suspended | cancelled
  planId              String   @map("plan_id")
  regionPolicy        String?  @map("region_policy")
  tier                Int      @default(1) // 1=Shared 2=DedicatedNS 3=DedicatedCluster
  billingAccountId    String?  @map("billing_account_id")
  primaryRegion       String?  @map("primary_region")
  allowedRegions      String[] @map("allowed_regions")
  dataResidencyRequired Boolean @default(false) @map("data_residency_required")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  settings                TenantSettings?
  memberships             Membership[]
  rbacRoles               RbacRole[]
  workflows               Workflow[]
  executions              WorkflowExecution[]
  dashboards              Dashboard[]
  dataSources             DataSource[]
  tenantConnectorInstalls TenantConnectorInstall[]
  tenantCredentials       TenantCredential[]
  environments            Environment[]
  meteringEvents          MeteringEvent[]
  usageRollups            UsageRollup[]
  billingAccount          BillingAccount?
  tokenBudgets            TokenBudget[]
  aiPrompts               AiPrompt[]
  aiUsage                 AiUsage[]
  aiEvalDatasets          AiEvalDataset[]
  knowledgeBases          KnowledgeBase[]
  featureFlags            FeatureFlag[]
  webhookDeliveries       WebhookDelivery[]

  @@map("tenants")
}

/// Per-tenant configuration and policy overrides (Section 29.2 / ADR-012)
model TenantSettings {
  id                        String   @id @default(cuid())
  tenantId                  String   @unique @map("tenant_id")
  retentionHotMonths        Int      @default(13) @map("retention_hot_months")
  retentionColdYears        Int      @default(7)  @map("retention_cold_years")
  maxWorkflowCount          Int?     @map("max_workflow_count")
  maxExecutionConcurrency   Int?     @map("max_execution_concurrency")
  maxConnectorInstalls      Int?     @map("max_connector_installs")
  maxAiRequestsPerDay       Int?     @map("max_ai_requests_per_day")
  allowedRegions            String[] @map("allowed_regions")
  allowedAuthProviders      String[] @map("allowed_auth_providers")
  ipAllowlist               String[] @map("ip_allowlist")
  webhookRequireSignature   Boolean  @default(true)  @map("webhook_require_signature")
  auditRetentionDays        Int      @default(90)    @map("audit_retention_days")
  sessionTimeoutMinutes     Int      @default(480)   @map("session_timeout_minutes")
  mfaRequired               Boolean  @default(false) @map("mfa_required")
  ssoRequired               Boolean  @default(false) @map("sso_required")
  features                  Json     @default("{}") @map("features")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model User {
  id                         String    @id @default(cuid())
  email                      String    @unique
  passwordHash               String    @map("password_hash")
  name                       String
  status                     String    @default("active") // active | deactivated
  locale                     String?
  profileJson                Json?     @map("profile_json")
  avatarUrl                  String?   @map("avatar_url")
  emailVerifiedAt            DateTime? @map("email_verified_at")
  lastLoginAt                DateTime? @map("last_login_at")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  memberships         Membership[]
  auditLogs           AuditLog[]
  workflowVersions    WorkflowVersion[]
  approvalTasksOwned  ApprovalTask[]    @relation("approvalRequester")
  approvalTasksApprove ApprovalTask[]   @relation("approvalApprover")

  @@index([email])
  @@map("users")
}

model Membership {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tenantId   String    @map("tenant_id")
  roleId     String?   @map("role_id")
  status     String    @default("active") // active | invited | deactivated
  invitedBy  String?   @map("invited_by")
  joinedAt   DateTime  @default(now()) @map("joined_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   RbacRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([userId, tenantId])
  @@index([tenantId, userId])
  @@map("memberships")
}

model RbacRole {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  name        String
  scope       String   // platform | tenant | environment | resource
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  memberships     Membership[]

  @@index([tenantId, name])
  @@map("rbac_roles")
}

model RbacPermission {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. workflow.publish, execution.retry
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("rbac_permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       RbacRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission RbacPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// =============================================================================
// Domain: Workflow
// =============================================================================

model Workflow {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  name             String
  description      String?
  status           String    @default("draft") // draft | active | inactive | archived
  triggerType      String    @default("manual") @map("trigger_type")
  currentVersionId String?   @map("current_version_id")
  tags             String[]
  nodeCount        Int       @default(0) @map("node_count")
  executionCount   Int       @default(0) @map("execution_count")
  lastRunAt        DateTime? @map("last_run_at")
  lastRunStatus    String?   @map("last_run_status")
  region           String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currentVersion  WorkflowVersion?  @relation("currentVersion", fields: [currentVersionId], references: [id])
  versions        WorkflowVersion[] @relation("allVersions")
  executions      WorkflowExecution[]
  diffs           WorkflowDiff[]
  approvalTasks   ApprovalTask[]

  @@index([tenantId, status])
  @@index([tenantId, name])
  @@map("workflows")
}

/// Immutable published snapshot — graph_json is write-once (Section 9 / ADR-005)
model WorkflowVersion {
  id             String   @id @default(cuid())
  workflowId     String   @map("workflow_id")
  versionNumber  Int      @map("version_number")
  graphJson      Json     @map("graph_json")
  checksum       String
  releaseNotes   String?  @map("release_notes")
  createdById    String?  @map("created_by_id")
  publishedAt    DateTime @default(now()) @map("published_at")
  createdAt      DateTime @default(now()) @map("created_at")

  workflow    Workflow          @relation("allVersions", fields: [workflowId], references: [id], onDelete: Cascade)
  currentFor  Workflow[]        @relation("currentVersion")
  createdBy   User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  executions  WorkflowExecution[]
  diffsFrom   WorkflowDiff[]    @relation("diffFrom")
  diffsTo     WorkflowDiff[]    @relation("diffTo")

  @@unique([workflowId, versionNumber])
  @@index([workflowId])
  @@map("workflow_versions")
}

/// JSON Patch between two versions — ADR-005
model WorkflowDiff {
  id           String   @id @default(cuid())
  workflowId   String   @map("workflow_id")
  fromVersionId String  @map("from_version_id")
  toVersionId   String  @map("to_version_id")
  patchJson     Json    @map("patch_json") // RFC 6902 JSON Patch array
  patchHash     String  @map("patch_hash")
  summary       Json?   // semantic summary: nodes added/removed/changed
  createdBy     String? @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  workflow    Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromVersion WorkflowVersion @relation("diffFrom", fields: [fromVersionId], references: [id], onDelete: Cascade)
  toVersion   WorkflowVersion @relation("diffTo",   fields: [toVersionId],   references: [id], onDelete: Cascade)

  @@index([workflowId, fromVersionId, toVersionId])
  @@map("workflow_diffs")
}

// =============================================================================
// Domain: Execution
// =============================================================================

/// Partitioned monthly by started_at — hot 13 months, cold 7 years (ADR-012)
model WorkflowExecution {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  workflowId        String    @map("workflow_id")
  workflowVersionId String    @map("workflow_version_id")
  status            String    @default("pending") // pending|running|success|failed|cancelled|timed_out
  triggerType       String    @map("trigger_type") // manual|schedule|webhook|event|api
  startedAt         DateTime  @default(now()) @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  durationMs        Int?      @map("duration_ms")
  errorMessage      String?   @map("error_message")
  region            String?
  createdAt         DateTime  @default(now()) @map("created_at")

  tenant          Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow        Workflow                    @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  workflowVersion WorkflowVersion             @relation(fields: [workflowVersionId], references: [id], onDelete: Restrict)
  checkpoints     NodeExecutionCheckpoint[]
  leases          ExecutionLease[]
  deadLetterItems DeadLetterQueue[]

  @@index([tenantId, workflowId])
  @@index([workflowId, startedAt])
  @@index([status, startedAt])
  @@map("workflow_executions")
}

/// Per-node checkpoint for crash recovery — Section 9.7
model NodeExecutionCheckpoint {
  id          String   @id @default(cuid())
  executionId String   @map("execution_id")
  nodeId      String   @map("node_id")
  attempt     Int
  stateJson   Json     @map("state_json")
  createdAt   DateTime @default(now()) @map("created_at")

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([executionId, nodeId, attempt])
  @@index([executionId, nodeId, attempt])
  @@map("node_execution_checkpoints")
}

/// Distributed lease — prevents dual-execution on crash recovery
model ExecutionLease {
  id          String   @id @default(cuid())
  executionId String   @map("execution_id")
  workerId    String   @map("worker_id")
  leasedUntil DateTime @map("leased_until")
  createdAt   DateTime @default(now()) @map("created_at")

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([executionId, workerId])
  @@map("execution_leases")
}

/// Append-only; items that exhausted all retry attempts
model DeadLetterQueue {
  id          String   @id @default(cuid())
  executionId String   @map("execution_id")
  nodeId      String   @map("node_id")
  reason      String
  payloadJson Json     @map("payload_json")
  status      String   @default("pending") // pending | requeued | discarded
  createdAt   DateTime @default(now()) @map("created_at")

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@map("dead_letter_queue")
}

// =============================================================================
// Domain: Connector
// =============================================================================

model Connector {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  displayName  String?  @map("display_name")
  description  String?
  icon         String?
  category     String
  trustLevel   String   @default("community") @map("trust_level") // first_party|partner|community
  scope        String?  // e.g. "read:repo,write:issues"
  authType     String   @default("apikey") @map("auth_type")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  versions ConnectorVersion[]

  @@map("connectors")
}

model ConnectorVersion {
  id          String   @id @default(cuid())
  connectorId String   @map("connector_id")
  semver      String
  manifestJson Json    @map("manifest_json")
  artifactRef  String? @map("artifact_ref")
  signatureRef String? @map("signature_ref")
  isSupported  Boolean @default(true) @map("is_supported")
  publishedAt  DateTime @default(now()) @map("published_at")
  createdAt    DateTime @default(now()) @map("created_at")

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  installs    TenantConnectorInstall[]

  @@unique([connectorId, semver])
  @@map("connector_versions")
}

model TenantConnectorInstall {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  connectorVersionId String   @map("connector_version_id")
  status             String   @default("active") // active | disabled | pending
  installedAt        DateTime @default(now()) @map("installed_at")
  installedBy        String?  @map("installed_by")
  config             Json     @default("{}") @map("config")
  createdAt          DateTime @default(now()) @map("created_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectorVersion ConnectorVersion @relation(fields: [connectorVersionId], references: [id], onDelete: Restrict)
  credentials      TenantCredential[]

  @@unique([tenantId, connectorVersionId])
  @@index([tenantId, status])
  @@map("tenant_connector_installs")
}

model TenantCredential {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  connectorInstallId String  @map("connector_install_id")
  secretRef        String   @map("secret_ref") // Vault path
  status           String   @default("active") // active | revoked | expired
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectorInstall TenantConnectorInstall @relation(fields: [connectorInstallId], references: [id], onDelete: Cascade)

  @@map("tenant_credentials")
}

// =============================================================================
// Domain: Dashboard
// =============================================================================

model Dashboard {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  title            String
  description      String?
  status           String   @default("draft") // draft | published
  layoutVersion    Int      @default(1) @map("layout_version")
  currentVersionId String?  @map("current_version_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currentVersion DashboardVersion? @relation("currentVersion", fields: [currentVersionId], references: [id])
  versions       DashboardVersion[] @relation("allVersions")

  @@index([tenantId, status])
  @@map("dashboards")
}

model DashboardVersion {
  id            String   @id @default(cuid())
  dashboardId   String   @map("dashboard_id")
  versionNumber Int      @map("version_number")
  layoutJson    Json     @map("layout_json")
  checksum      String
  createdBy     String?  @map("created_by")
  publishedAt   DateTime @default(now()) @map("published_at")
  createdAt     DateTime @default(now()) @map("created_at")

  dashboard  Dashboard        @relation("allVersions", fields: [dashboardId], references: [id], onDelete: Cascade)
  currentFor Dashboard[]      @relation("currentVersion")
  widgets    DashboardWidget[]

  @@unique([dashboardId, versionNumber])
  @@map("dashboard_versions")
}

model DashboardWidget {
  id                 String @id @default(cuid())
  dashboardVersionId String @map("dashboard_version_id")
  widgetId           String @map("widget_id")
  type               String
  title              String?
  configJson         Json   @map("config_json")
  positionJson       Json   @map("position_json") // {x, y, w, h}
  createdAt          DateTime @default(now()) @map("created_at")

  dashboardVersion DashboardVersion @relation(fields: [dashboardVersionId], references: [id], onDelete: Cascade)

  @@map("dashboard_widgets")
}

model DataSource {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  kind      String   // postgres | mysql | rest | graphql | ...
  name      String
  configJson Json    @map("config_json") // connection params (secrets via Vault ref)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("data_sources")
}

// =============================================================================
// Domain: Template
// =============================================================================

model Template {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String
  visibility   String   @default("public") // public | team | private
  status       String   @default("draft") // draft | published | deprecated
  sourceType   String   @default("workflow") @map("source_type") // workflow | dashboard
  installCount Int      @default(0) @map("install_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  versions TemplateVersion[]

  @@map("templates")
}

model TemplateVersion {
  id           String   @id @default(cuid())
  templateId   String   @map("template_id")
  semver       String
  manifestJson Json     @map("manifest_json")
  publishedAt  DateTime @default(now()) @map("published_at")
  createdAt    DateTime @default(now()) @map("created_at")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, semver])
  @@map("template_versions")
}

// =============================================================================
// Domain: Environment
// =============================================================================

model Environment {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  name       String   // dev | staging | prod
  type       String   @default("standard")
  policyJson Json     @default("{}") @map("policy_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  releases EnvironmentRelease[]

  @@unique([tenantId, name])
  @@map("environments")
}

/// Tracks which artifact version is deployed to which environment
model EnvironmentRelease {
  id               String    @id @default(cuid())
  environmentId    String    @map("environment_id")
  artifactType     String    @map("artifact_type") // workflow | dashboard | template
  sourceVersionId  String    @map("source_version_id")
  approvedBy       String?   @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  deployedBy       String    @map("deployed_by")
  status           String    @default("pending") // pending | approved | deployed | rolled_back
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([environmentId, artifactType])
  @@map("environment_releases")
}

// =============================================================================
// Domain: Approval
// =============================================================================

model ApprovalTask {
  id          String    @id @default(cuid())
  workflowId  String    @map("workflow_id")
  requesterId String    @map("requester_id")
  approverId  String?   @map("approver_id")
  status      String    @default("pending") // pending | approved | rejected | escalated
  dueAt       DateTime? @map("due_at")
  escalatedAt DateTime? @map("escalated_at")
  resolvedAt  DateTime? @map("resolved_at")
  comment     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workflow  Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  requester User     @relation("approvalRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  approver  User?    @relation("approvalApprover",  fields: [approverId],  references: [id], onDelete: SetNull)

  @@index([workflowId, status])
  @@map("approval_tasks")
}

// =============================================================================
// Domain: Billing
// =============================================================================

/// High-volume append-only — partitioned monthly by occurred_at
model MeteringEvent {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  eventType  String   @map("event_type") // workflow_execution | ai_token | connector_call | ...
  quantity   Float
  occurredAt DateTime @default(now()) @map("occurred_at")
  metadata   Json     @default("{}")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, eventType, occurredAt])
  @@map("metering_events")
}

/// Pre-aggregated rollups for billing and dashboards
model UsageRollup {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  metricCode  String   @map("metric_code")
  quantity    Float
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, periodStart, periodEnd, metricCode])
  @@index([tenantId, periodStart])
  @@map("usage_rollups")
}

model BillingAccount {
  id          String   @id @default(cuid())
  tenantId    String   @unique @map("tenant_id")
  providerRef String   @map("provider_ref") // Stripe customer ID or equivalent
  status      String   @default("active") // active | past_due | cancelled
  currency    String   @default("usd")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@map("billing_accounts")
}

model Invoice {
  id               String   @id @default(cuid())
  billingAccountId String   @map("billing_account_id")
  invoiceNumber    String   @unique @map("invoice_number")
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")
  status           String   @default("draft") // draft | open | paid | void
  totalAmount      Float    @default(0) @map("total_amount")
  currency         String   @default("usd")
  paidAt           DateTime? @map("paid_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  lines          InvoiceLine[]

  @@map("invoices")
}

model InvoiceLine {
  id         String  @id @default(cuid())
  invoiceId  String  @map("invoice_id")
  metricCode String  @map("metric_code")
  quantity   Float
  unitPrice  Float   @map("unit_price")
  amount     Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_lines")
}

/// Per-tenant AI token budget with alert thresholds (Section 8.10)
model TokenBudget {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  period         String   @default("monthly") // monthly | daily
  monthlyLimit   Int      @map("monthly_limit")  // tokens
  alert50        Int      @map("alert_50")        // alert at 50% usage
  alert80        Int      @map("alert_80")        // alert at 80% usage
  hardCutoffAt   Int      @map("hard_cutoff_at")  // reject requests beyond this
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, period])
  @@map("token_budgets")
}

// =============================================================================
// Domain: AI
// =============================================================================

/// Global model registry — managed by platform team
model AiModel {
  id            String   @id @default(cuid())
  provider      String   // openai | anthropic | google | cohere | ...
  modelName     String   @map("model_name")
  contextWindow Int      @map("context_window")
  priceJson     Json     @map("price_json") // {input_per_1k: n, output_per_1k: n}
  riskTags      String[] @map("risk_tags")  // [pii_risk, high_cost, experimental]
  status        String   @default("active") // active | deprecated | disabled
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  usage AiUsage[]

  @@unique([provider, modelName])
  @@map("ai_models")
}

model AiPrompt {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  name             String
  description      String?
  status           String   @default("draft") // draft | active | deprecated
  currentVersionId String?  @map("current_version_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currentVersion AiPromptVersion?  @relation("currentVersion", fields: [currentVersionId], references: [id])
  versions       AiPromptVersion[] @relation("allVersions")
  evalDatasets   AiEvalDataset[]

  @@map("ai_prompts")
}

model AiPromptVersion {
  id              String   @id @default(cuid())
  promptId        String   @map("prompt_id")
  versionNumber   Int      @map("version_number")
  templateText    String   @map("template_text")
  parametersJson  Json     @map("parameters_json") // variable definitions
  checksum        String
  createdBy       String?  @map("created_by")
  publishedAt     DateTime @default(now()) @map("published_at")
  createdAt       DateTime @default(now()) @map("created_at")

  prompt     AiPrompt      @relation("allVersions", fields: [promptId], references: [id], onDelete: Cascade)
  currentFor AiPrompt[]    @relation("currentVersion")
  evalRuns   AiEvalRun[]

  @@unique([promptId, versionNumber])
  @@map("ai_prompt_versions")
}

/// Append-only per-run AI usage — partitioned monthly by occurred_at
model AiUsage {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  modelId          String   @map("model_id")
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  cachedTokens     Int      @default(0) @map("cached_tokens")
  costUsd          Float    @map("cost_usd")
  runId            String?  @map("run_id")
  occurredAt       DateTime @default(now()) @map("occurred_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  model  AiModel @relation(fields: [modelId], references: [id], onDelete: Restrict)

  @@index([tenantId, modelId, occurredAt])
  @@map("ai_usage")
}

/// Golden test pairs for offline evaluation
model AiEvalDataset {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  promptId      String   @map("prompt_id")
  name          String
  description   String?
  goldenPairsJson Json   @map("golden_pairs_json") // [{input, expected_output}]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prompt   AiPrompt    @relation(fields: [promptId], references: [id], onDelete: Cascade)
  evalRuns AiEvalRun[]

  @@map("ai_eval_datasets")
}

/// Result of a prompt-version evaluation run (Section 8.8)
model AiEvalRun {
  id              String   @id @default(cuid())
  promptVersionId String   @map("prompt_version_id")
  datasetId       String   @map("dataset_id")
  score           Float    // aggregate score 0-1
  scorerType      String   @map("scorer_type") // exact_match | llm_judge | human | ...
  resultsJson     Json     @map("results_json") // per-pair results
  createdAt       DateTime @default(now()) @map("created_at")

  promptVersion AiPromptVersion @relation(fields: [promptVersionId], references: [id], onDelete: Cascade)
  dataset       AiEvalDataset   @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([promptVersionId, datasetId])
  @@map("ai_eval_runs")
}

// =============================================================================
// Domain: RAG
// =============================================================================

/// Knowledge base configuration — uses pgvector for embeddings (ADR-003)
model KnowledgeBase {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  name            String
  description     String?
  embeddingModel  String   @map("embedding_model") // e.g. text-embedding-3-small
  chunkingConfig  Json     @map("chunking_config")  // {size, overlap, strategy}
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents KnowledgeDocument[]

  @@index([tenantId])
  @@map("knowledge_bases")
}

model KnowledgeDocument {
  id              String   @id @default(cuid())
  knowledgeBaseId String   @map("knowledge_base_id")
  sourceRef       String   @map("source_ref") // S3 key, URL, or inline ref
  status          String   @default("pending") // pending | processing | ready | error
  chunkCount      Int      @default(0) @map("chunk_count")
  metadata        Json     @default("{}")
  processedAt     DateTime? @map("processed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  knowledgeBase KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  embeddings    VectorEmbedding[]

  @@index([knowledgeBaseId, status])
  @@map("knowledge_documents")
}

/// pgvector column — dimension N set per knowledge base embedding model
model VectorEmbedding {
  id           String   @id @default(cuid())
  documentId   String   @map("document_id")
  chunkIndex   Int      @map("chunk_index")
  content      String   // raw chunk text
  // embedding stored as Unsupported until Prisma has native vector support
  embedding    Unsupported("vector(1536)")
  metadataJson Json     @default("{}") @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, chunkIndex])
  @@map("vector_embeddings")
}

// =============================================================================
// Domain: Audit
// =============================================================================

/// Append-only — partitioned monthly by occurred_at, retained 90d hot / 7y cold
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String   @map("actor_id")
  action     String   // e.g. workflow.publish, execution.retry
  targetType String   @map("target_type") // Workflow | Connector | ...
  targetId   String   @map("target_id")
  diffJson   Json?    @map("diff_json")
  occurredAt DateTime @default(now()) @map("occurred_at")

  actor User @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId, occurredAt])
  @@index([targetType, targetId])
  @@index([occurredAt])
  @@map("audit_logs")
}

// =============================================================================
// Domain: Platform
// =============================================================================

/// Append-only event ledger for internal event sourcing — partitioned monthly
model PlatformEvent {
  id          String   @id @default(cuid())
  eventType   String   @map("event_type")
  eventVersion Int     @default(1) @map("event_version")
  aggregateId String   @map("aggregate_id")
  payloadJson Json     @map("payload_json")
  occurredAt  DateTime @default(now()) @map("occurred_at")

  @@index([eventType, aggregateId])
  @@index([occurredAt])
  @@map("platform_events")
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  endpointId    String   @map("endpoint_id")
  tenantId      String   @map("tenant_id")
  eventType     String   @map("event_type")
  payloadJson   Json     @map("payload_json")
  status        String   @default("pending") // pending | delivered | failed
  retryCount    Int      @default(0) @map("retry_count")
  nextAttemptAt DateTime? @map("next_attempt_at")
  deliveredAt   DateTime? @map("delivered_at")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([endpointId])
  @@map("webhook_deliveries")
}

model FeatureFlag {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id") // null = global default
  key       String
  valueJson Json     @map("value_json")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, key])
  @@map("feature_flags")
}
