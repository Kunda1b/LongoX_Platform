model ReportingReadModel {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  reportType String   @map("report_type")
  data       Json
  period     String
  computedAt DateTime @default(now()) @map("computed_at")

  @@index([tenantId, reportType, period])
  @@map("reporting_read_models")
}

// =============================================================================
// Domain: Region Policy
// =============================================================================

model RegionPolicy {
  id                String   @id @default(cuid())
  name              String
  region            String
  tier              String   @default("standard")
  replicationFactor Int      @default(1) @map("replication_factor")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([name, region])
  @@map("region_policies")
}

// =============================================================================
// Domain: Email Messages
// =============================================================================

model EmailMessage {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  to        String
  subject   String
  body      String
  status    String    @default("pending")
  sentAt    DateTime? @map("sent_at")
  error     String?
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tenantId, status])
  @@map("email_messages")
}

// =============================================================================
// Domain: Event Bus — Consumer Offsets (ADR-013 Phase 3 / §19.3)
// =============================================================================
// Per architecture.md §19.3, consumer_offsets is the at-least-once delivery
// dedupe table. Drizzle had it; Prisma was missing it. Now added.
// PK: (consumer_name, event_id) — composite, matches §19.3 exactly.
// Index: (consumer_name, processed_at DESC) — for "find next unprocessed" queries.

model ConsumerOffset {
  consumerName String   @map("consumer_name")
  eventId      String   @map("event_id")
  aggregateId  String   @map("aggregate_id")
  processedAt  DateTime @default(now()) @map("processed_at")
  status       String   @default("processing") // CHECK IN ('processing','completed','failed','dead_letter')
  error        String?

  @@id([consumerName, eventId])
  @@index([consumerName, processedAt])
  @@map("consumer_offsets")
}

// =============================================================================
// Domain: AI — Token Usage (ADR-013 Phase 3)
// =============================================================================
// Per architecture.md §10.1 ai_usage table and ADR-013 Phase 2 P1 ai-service
// migration row, this table records per-request AI token usage for billing
// traceability (invoice_lines → usage_rollups → metering_events drill-down,
// SOC 2 requirement). Drizzle had it as token_usage; Prisma was missing it.

model TokenUsage {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @map("tenant_id")
  modelId      Int?     @map("model_id")
  modelName    String?  @map("model_name")
  provider     String?
  promptId     Int?     @map("prompt_id")
  workflowId   Int?     @map("workflow_id")
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  cost         Decimal  @default(0) @db.Decimal(12, 6)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([workflowId])
  @@index([promptId])
  @@map("token_usage")
}
