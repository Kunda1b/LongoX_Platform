{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.longox.com/events/ai.run.completed.v1.json",
  "title": "ai.run.completed v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "tenant_id",
    "correlation_id",
    "aggregate_id",
    "actor_id",
    "payload",
    "schema_url"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_"
    },
    "event_type": {
      "const": "ai.run.completed"
    },
    "event_version": {
      "const": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": ["string", "null"]
    },
    "correlation_id": {
      "type": ["string", "null"]
    },
    "aggregate_id": {
      "type": "string",
      "pattern": "^ai_"
    },
    "actor_id": {
      "type": ["string", "null"]
    },
    "payload": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": "string"
        },
        "tenant_id": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["run_id", "tenant_id", "model", "provider"]
    },
    "schema_url": {
      "type": "string",
      "format": "uri"
    }
  }
}
