{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.longox.com/events/template.published.v1.json",
  "title": "template.published v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "tenant_id",
    "correlation_id",
    "aggregate_id",
    "actor_id",
    "payload",
    "schema_url"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_"
    },
    "event_type": {
      "const": "template.published"
    },
    "event_version": {
      "const": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": ["string", "null"]
    },
    "correlation_id": {
      "type": ["string", "null"]
    },
    "aggregate_id": {
      "type": "string",
      "pattern": "^tpl_"
    },
    "actor_id": {
      "type": ["string", "null"]
    },
    "payload": {
      "type": "object",
      "properties": {
        "template_id": {
          "type": "string"
        },
        "version_id": {
          "type": "string"
        },
        "version_number": {
          "type": "integer",
          "minimum": 1
        },
        "checksum": {
          "type": "string"
        },
        "category": {
          "type": "string"
        }
      },
      "required": ["template_id", "version_id", "version_number"]
    },
    "schema_url": {
      "type": "string",
      "format": "uri"
    }
  }
}
