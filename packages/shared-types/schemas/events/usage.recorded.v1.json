{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.longox.com/events/usage.recorded.v1.json",
  "title": "usage.recorded v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "tenant_id",
    "correlation_id",
    "aggregate_id",
    "actor_id",
    "payload",
    "schema_url"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_"
    },
    "event_type": {
      "const": "usage.recorded"
    },
    "event_version": {
      "const": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": ["string", "null"]
    },
    "correlation_id": {
      "type": ["string", "null"]
    },
    "aggregate_id": {
      "type": "string",
      "pattern": "^tnt_"
    },
    "actor_id": {
      "type": ["string", "null"]
    },
    "payload": {
      "type": "object",
      "properties": {
        "tenant_id": {
          "type": "string"
        },
        "metric_code": {
          "type": "string"
        },
        "quantity": {
          "type": "number",
          "minimum": 0
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["tenant_id", "metric_code", "quantity"]
    },
    "schema_url": {
      "type": "string",
      "format": "uri"
    }
  }
}
