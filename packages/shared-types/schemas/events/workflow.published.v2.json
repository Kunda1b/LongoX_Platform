{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.longox.com/events/workflow.published.v2.json",
  "title": "workflow.published v2",
  "type": "object",
  "required": [
    "event_id", "event_type", "event_version", "occurred_at",
    "tenant_id", "correlation_id", "aggregate_id", "actor_id",
    "payload", "schema_url"
  ],
  "properties": {
    "event_id": { "type": "string", "pattern": "^evt_" },
    "event_type": { "const": "workflow.published" },
    "event_version": { "const": 2 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string", "pattern": "^tnt_" },
    "correlation_id": { "type": "string" },
    "aggregate_id": { "type": "string", "pattern": "^wf_" },
    "actor_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["workflow_id", "version_id", "version_number", "checksum"],
      "properties": {
        "workflow_id": { "type": "string" },
        "version_id": { "type": "string" },
        "version_number": { "type": "integer", "minimum": 1 },
        "checksum": { "type": "string" },
        "release_notes": { "type": "string" }
      }
    },
    "schema_url": { "type": "string", "format": "uri" }
  }
}
