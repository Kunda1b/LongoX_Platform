{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.longox.com/events/execution.started.v1.json",
  "title": "execution.started v1",
  "type": "object",
  "required": [
    "event_id", "event_type", "event_version", "occurred_at",
    "tenant_id", "correlation_id", "aggregate_id", "actor_id",
    "payload", "schema_url"
  ],
  "properties": {
    "event_id": { "type": "string", "pattern": "^evt_" },
    "event_type": { "const": "execution.started" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string", "pattern": "^tnt_" },
    "correlation_id": { "type": "string" },
    "aggregate_id": { "type": "string", "pattern": "^exec_" },
    "actor_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["execution_id", "workflow_id", "trigger_type"],
      "properties": {
        "execution_id": { "type": "string" },
        "workflow_id": { "type": "string" },
        "workflow_version": { "type": "integer" },
        "trigger_type": { "type": "string" },
        "input_size": { "type": "integer" }
      }
    },
    "schema_url": { "type": "string", "format": "uri" }
  }
}
