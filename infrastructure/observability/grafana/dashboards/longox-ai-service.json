{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "AI Requests / sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(longox_ai_requests_total[5m])",
          "legendFormat": "{{provider}}"
        },
        {
          "expr": "rate(longox_ai_requests_failed_total[5m])",
          "legendFormat": "{{provider}} - failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Token Usage / min",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(longox_ai_tokens_total[5m]) * 60",
          "legendFormat": "{{token_type}} ({{provider}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Request Latency P50/P95/P99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(longox_ai_request_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p50 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(longox_ai_request_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(longox_ai_request_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p99 {{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Token Efficiency (tokens/request)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(longox_ai_tokens_total{token_type=\"prompt\"}[5m]) / rate(longox_ai_requests_total[5m])",
          "legendFormat": "prompt tokens/req ({{provider}})"
        },
        {
          "expr": "rate(longox_ai_tokens_total{token_type=\"completion\"}[5m]) / rate(longox_ai_requests_total[5m])",
          "legendFormat": "completion tokens/req ({{provider}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Provider Error Breakdown",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(longox_ai_requests_failed_total[1h])) by (provider, error_type)",
          "legendFormat": "{{provider}} - {{error_type}}"
        }
      ]
    },
    {
      "title": "Success Rate by Provider",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(longox_ai_requests_total[5m])) by (provider) / (sum(rate(longox_ai_requests_total[5m])) by (provider) + sum(rate(longox_ai_requests_failed_total[5m])) by (provider)) * 100",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 95, "color": "yellow" }, { "value": 99, "color": "green" }] }
        }
      }
    },
    {
      "title": "Total Tokens (24h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(longox_ai_tokens_total[24h])) by (token_type)",
          "legendFormat": "{{token_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["longox", "ai"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "LongoX AI Service",
  "uid": "longox-ai",
  "version": 1,
  "refresh": "30s"
}
