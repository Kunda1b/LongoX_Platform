{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "SLO tracking — error budget, status matrix, burn rates, success rates, and multi-window burn rate alerts",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "API Gateway", "url": "/d/api-gateway-dashboard", "type": "dashboards" },
    { "title": "Workflows", "url": "/d/workflow-dashboard", "type": "dashboards" },
    { "title": "AI Service", "url": "/d/ai-dashboard", "type": "dashboards" },
    { "title": "Infrastructure", "url": "/d/infrastructure-dashboard", "type": "dashboards" },
    { "title": "Business", "url": "/d/business-dashboard", "type": "dashboards" }
  ],
  "panels": [
    {
      "title": "SLO Status Matrix",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "slo:gateway:success_rate:30d",
          "legendFormat": "API Gateway"
        },
        {
          "expr": "slo:auth:success_rate:30d",
          "legendFormat": "Auth"
        },
        {
          "expr": "slo:billing:success_rate:30d",
          "legendFormat": "Billing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.99 },
            { "color": "green", "value": 0.999 }
          ]},
          "custom": {
            "displayMode": "grid",
            "minWidth": 150
          }
        }
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Error Budget Remaining — API Gateway",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "slo:budget_remaining:gateway",
          "legendFormat": "budget remaining"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green", "value": 90 }
          ]}
        }
      },
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Error Budget Remaining — Auth",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 6 },
      "targets": [
        {
          "expr": "slo:budget_remaining:auth",
          "legendFormat": "budget remaining"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green", "value": 90 }
          ]}
        }
      },
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Error Budget Remaining — Billing",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 6 },
      "targets": [
        {
          "expr": "slo:budget_remaining:billing",
          "legendFormat": "budget remaining"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green", "value": 90 }
          ]}
        }
      },
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Burn Rate Alerts (Heatmap)",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "slo:burn_rate:gateway",
          "legendFormat": "gateway",
          "format": "heatmap"
        },
        {
          "expr": "slo:burn_rate:auth",
          "legendFormat": "auth",
          "format": "heatmap"
        },
        {
          "expr": "slo:burn_rate:billing",
          "legendFormat": "billing",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "short" },
        "rows": { "mode": "auto" }
      }
    },
    {
      "title": "30d Success Rate — Gateway",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "slo:gateway:success_rate:30d",
          "legendFormat": "success rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.995 },
            { "color": "green", "value": 0.999 }
          ]}
        }
      }
    },
    {
      "title": "30d Success Rate — Auth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "slo:auth:success_rate:30d",
          "legendFormat": "success rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.9990 },
            { "color": "green", "value": 0.9995 }
          ]}
        }
      }
    },
    {
      "title": "30d Success Rate — Billing",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 12 },
      "targets": [
        {
          "expr": "slo:billing:success_rate:30d",
          "legendFormat": "success rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.9998 },
            { "color": "green", "value": 0.9999 }
          ]}
        }
      }
    },
    {
      "title": "Latency SLO — Workflow Publish P99 (target <500ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "slo:workflow_publish:latency_p99:7d",
          "legendFormat": "p99 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "red", "value": 0.5 }
          ]}
        }
      }
    },
    {
      "title": "Latency SLO — Execution Duration P99 (target <30s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 18 },
      "targets": [
        {
          "expr": "slo:execution:duration_p99:7d",
          "legendFormat": "p99 duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 20 },
            { "color": "red", "value": 30 }
          ]}
        }
      }
    },
    {
      "title": "Latency SLO — AI Response P99 (target <5s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 18 },
      "targets": [
        {
          "expr": "slo:ai:response_p99:7d",
          "legendFormat": "p99 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 3 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },
    {
      "title": "Multi-Window Burn Rate (5m / 30m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "slo:burn_rate:gateway",
          "legendFormat": "gateway"
        },
        {
          "expr": "slo:burn_rate:auth",
          "legendFormat": "auth"
        },
        {
          "expr": "slo:burn_rate:billing",
          "legendFormat": "billing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 6 },
            { "color": "red", "value": 14 }
          ]}
        }
      }
    },
    {
      "title": "SLO Trend — 7d Moving Average",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "avg_over_time(slo:gateway:success_rate:30d[7d])",
          "legendFormat": "gateway (7d avg)"
        },
        {
          "expr": "avg_over_time(slo:auth:success_rate:30d[7d])",
          "legendFormat": "auth (7d avg)"
        },
        {
          "expr": "avg_over_time(slo:billing:success_rate:30d[7d])",
          "legendFormat": "billing (7d avg)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.99 },
            { "color": "green", "value": 0.999 }
          ]}
        }
      }
    },
    {
      "title": "Queue Depth SLO (target <1000)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "slo:queues:depth:1h",
          "legendFormat": "queue depth"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 1000 }
          ]}
        }
      }
    },
    {
      "title": "Global Error Rate SLO (target <0.1%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 32 },
      "targets": [
        {
          "expr": "slo:errors:rate:1h * 100",
          "legendFormat": "error rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.05 },
            { "color": "red", "value": 0.1 }
          ]}
        }
      }
    },
    {
      "title": "Cluster CPU Saturation (target <80%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 32 },
      "targets": [
        {
          "expr": "slo:cluster:cpu_saturation:5m * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 80 }
          ]}
        }
      }
    },
    {
      "title": "Search Latency P99 (target <200ms)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "slo:search:latency_p99:7d",
          "legendFormat": "p99 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 0.2 }
          ]}
        }
      }
    },
    {
      "title": "Error Budget Table",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "slo:budget_remaining:gateway",
          "format": "table",
          "instant": true,
          "legendFormat": "gateway"
        },
        {
          "expr": "slo:budget_remaining:auth",
          "format": "table",
          "instant": true,
          "legendFormat": "auth"
        },
        {
          "expr": "slo:budget_remaining:billing",
          "format": "table",
          "instant": true,
          "legendFormat": "billing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "align": "auto" },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green", "value": 90 }
          ]}
        }
      },
      "options": {
        "sortBy": [
          { "displayName": "Value #A", "desc": false }
        ]
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["longox", "slo", "observability"],
  "templating": {
    "list": [
      {
        "description": "Environment",
        "label": "Environment",
        "name": "env",
        "options": [
          { "selected": true, "text": "production", "value": "production" },
          { "selected": false, "text": "staging", "value": "staging" },
          { "selected": false, "text": "development", "value": "development" }
        ],
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "title": "LongoX SLO Dashboard",
  "uid": "slo-dashboard",
  "version": 1
}
