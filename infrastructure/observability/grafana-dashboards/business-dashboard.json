{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Business metrics — tenants, workflows, executions, MRR, connectors, marketplace, conversion funnel, tier distribution",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "SLO Dashboard", "url": "/d/slo-dashboard", "type": "dashboards" },
    { "title": "Infrastructure", "url": "/d/infrastructure-dashboard", "type": "dashboards" }
  ],
  "panels": [
    {
      "title": "Active Tenants",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "longox_active_tenants",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "green", "value": 10 }
          ]},
          "min": 0,
          "max": 1000
        }
      },
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Total Workflows",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "sum(longox_workflows_total)",
          "legendFormat": "total workflows"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "title": "Total Published Workflows",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum(longox_workflows_published_total)",
          "legendFormat": "published"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "title": "Daily Active Executions",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(longox_jobs_completed_total[24h]))",
          "legendFormat": "completed"
        },
        {
          "expr": "sum(increase(longox_jobs_failed_total[24h]))",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" }, "fillOpacity": 80 }
        }
      }
    },
    {
      "title": "MRR / Billing Revenue",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(increase(longox_billing_revenue_cents_total[24h])) / 100",
          "legendFormat": "daily revenue (USD)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 80 }
        }
      },
      "options": {
        "orientation": "auto",
        "showValue": "auto"
      }
    },
    {
      "title": "Connector Installs (by Connector)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(longox_connector_installs_total[5m])) by (connector)",
          "legendFormat": "{{ connector }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Marketplace Listing Views",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(longox_marketplace_views_total[5m]))",
          "legendFormat": "views/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Signup / Conversion Funnel",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(increase(longox_signup_funnel_total[24h])) by (stage)",
          "legendFormat": "{{ stage }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 80 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto"
      }
    },
    {
      "title": "Tenant Tier Distribution",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "targets": [
        {
          "expr": "sum(longox_tenants_by_tier) by (tier)",
          "legendFormat": "{{ tier }}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie",
        "reduceOptions": { "values": false, "calcs": ["sum"] }
      }
    },
    {
      "title": "Daily Active Users",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 14 },
      "targets": [
        {
          "expr": "sum(increase(longox_user_sessions_total[24h]))",
          "legendFormat": "DAU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "green", "value": 100 }
          ]}
        }
      }
    },
    {
      "title": "Churned Tenants (30d)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 14 },
      "targets": [
        {
          "expr": "sum(increase(longox_tenant_churn_total[30d]))",
          "legendFormat": "churned"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["longox", "business"],
  "templating": {
    "list": [
      {
        "description": "Environment",
        "label": "Environment",
        "name": "env",
        "options": [
          { "selected": true, "text": "production", "value": "production" },
          { "selected": false, "text": "staging", "value": "staging" },
          { "selected": false, "text": "development", "value": "development" }
        ],
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5m", "15m", "30m", "1h", "2h", "1d"],
    "time_options": ["1h", "6h", "12h", "24h", "2d", "7d", "30d", "90d"]
  },
  "title": "LongoX Business Metrics",
  "uid": "business-dashboard",
  "version": 1
}
