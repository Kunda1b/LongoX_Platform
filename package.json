{
  "name": "longox",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --if-present run typecheck",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "qs": ">=6.15.2",
      "esbuild": ">=0.25.0"
    },
    "onlyBuiltDependencies": [
      "@pnpm/exe",
      "@swc/core",
      "esbuild",
      "msgpackr-extract",
      "msw",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "pino-pretty": "^13.1.3"
  }
}
